NEXT_PUBLIC_ACTOR_ROLE=admin
NEXT_PUBLIC_ACTOR_NAME=Admin Console

# Production Railway backend reference
NEXT_PUBLIC_OPERATIONS_PROD_API_BASE_URL=https://marvelous-consideration-production.up.railway.app
NEXT_PUBLIC_OPERATIONS_PROD_HEALTH_URL=https://marvelous-consideration-production.up.railway.app

# Public frontend site URL for deployed QR page previews.
NEXT_PUBLIC_SITE_URL=https://buildai-dlc.vercel.app
